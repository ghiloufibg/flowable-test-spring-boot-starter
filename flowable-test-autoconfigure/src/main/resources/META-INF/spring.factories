org.springframework.boot.env.EnvironmentPostProcessor=\
com.flowabletest.autoconfigure.kafka.FlowableTestKafkaEnvironmentPostProcessor,\
com.flowabletest.autoconfigure.http.FlowableTestHttpStubEnvironmentPostProcessor,\
com.flowabletest.autoconfigure.deployment.FlowableTestProcessDeploymentEnvironmentPostProcessor

org.springframework.test.context.ContextCustomizerFactory=\
com.flowabletest.autoconfigure.http.MockExternalServiceContextCustomizerFactory,\
com.flowabletest.autoconfigure.kafka.EmbeddedFlowableKafkaContextCustomizerFactory,\
com.flowabletest.autoconfigure.isolation.StrictIsolationContextCustomizerFactory

org.springframework.test.context.TestExecutionListener=\
com.flowabletest.autoconfigure.kafka.FlowableKafkaConsumerLifecycleTestExecutionListener,\
com.flowabletest.autoconfigure.deployment.FlowableProcessAnnotationDeploymentTestExecutionListener
