<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:flowable="http://flowable.org/bpmn"
             targetNamespace="http://flowabletest.com/diagnostics">

    <process id="diagnosticsAsyncFailProcess" name="Diagnostics Async Fail Process" isExecutable="true">
        <startEvent id="startEvent" />
        <sequenceFlow id="flow1" sourceRef="startEvent" targetRef="riskyTask" />

        <serviceTask id="riskyTask" name="Risky task" flowable:async="true"
                     flowable:class="com.flowabletest.autoconfigure.testapp.AlwaysFailingDelegate" />
        <sequenceFlow id="flow2" sourceRef="riskyTask" targetRef="endEvent" />

        <endEvent id="endEvent" />
    </process>
</definitions>
