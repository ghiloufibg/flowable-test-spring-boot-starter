<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>com.flowabletest</groupId>
        <artifactId>flowable-test-spring-boot-starter-parent</artifactId>
        <version>0.1.0-SNAPSHOT</version>
    </parent>

    <artifactId>flowable-test-core</artifactId>
    <name>Flowable Test Starter - Core</name>
    <description>
        Annotations, DSL, and process-testing harness. No Spring Boot auto-configuration here;
        that lives in flowable-test-autoconfigure. Kafka/WireMock types are optional compile
        dependencies: the classes that use them (KafkaTestBridge, HttpStubConfigurer) are only
        ever loaded if the autoconfigure module actually activates that capability, so a consumer
        who never adds spring-kafka-test/wiremock never needs those classes resolvable.
    </description>

    <dependencies>
        <!-- Flowable API surface: provided, never propagated to consumers (design doc section 5.1) -->
        <dependency>
            <groupId>org.flowable</groupId>
            <artifactId>flowable-engine</artifactId>
            <scope>provided</scope>
        </dependency>

        <!-- Needed to compile @FlowableProcessTest as a composed annotation over @SpringBootTest -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-test</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springframework</groupId>
            <artifactId>spring-test</artifactId>
        </dependency>

        <dependency>
            <groupId>org.assertj</groupId>
            <artifactId>assertj-core</artifactId>
        </dependency>

        <!-- Needed to compile FlowableProcessDiagnosticsExtension (@ExtendWith target, referenced
             directly from the main-scope @FlowableProcessTest annotation). provided, not test,
             scope: same reasoning as flowable-engine above, the consumer's own
             spring-boot-starter-test always supplies the actual JUnit 5 runtime, so this must never
             become a transitive runtime dependency of its own. -->
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter-api</artifactId>
            <scope>provided</scope>
        </dependency>

        <!-- SLF4J API: used by FlowableProcessDiagnosticsExtension to log (never throw) when
             diagnostics collection itself fails. provided, not compile: Flowable itself requires
             slf4j-api at runtime, so the consumer always has a binding on their classpath already;
             this must not become a second, independently-versioned copy. -->
        <dependency>
            <groupId>org.slf4j</groupId>
            <artifactId>slf4j-api</artifactId>
            <scope>provided</scope>
        </dependency>

        <!-- Optional: only needed by KafkaTestBridge. Not propagated to consumers (design doc
             section 3/4.2); a consumer must add spring-kafka-test themselves to use this. -->
        <dependency>
            <groupId>org.apache.kafka</groupId>
            <artifactId>kafka-clients</artifactId>
            <optional>true</optional>
        </dependency>

        <!-- Optional: only needed by HttpStubConfigurer. Not propagated to consumers. -->
        <dependency>
            <groupId>org.wiremock</groupId>
            <artifactId>wiremock-standalone</artifactId>
            <optional>true</optional>
        </dependency>

        <!-- junit-jupiter-api itself is now provided-scope above (available on both compile and
             test classpaths); only the engine, needed purely to execute this module's own tests
             via Surefire and never referenced by any source, stays test-scope. -->
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter-engine</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
            </plugin>
        </plugins>
    </build>
</project>
